# ── Spotify OAuth ───────────────────────────────────────────────────────────
# Obtenha em: https://developer.spotify.com/dashboard
# Redirect URI deve ser cadastrada no painel do Spotify Developer
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id_here
VITE_SPOTIFY_REDIRECT_URI=http://localhost:5173/callback

# ── Last.fm API ──────────────────────────────────────────────────────────────
# Obtenha em: https://www.last.fm/api/account/create
VITE_LASTFM_API_KEY=your_lastfm_api_key_here
VITE_LASTFM_SHARED_SECRET=your_lastfm_shared_secret_here

